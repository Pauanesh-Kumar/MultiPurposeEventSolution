{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DatabaseConnection": "Data Source=DESKTOP-HFO63P7\\SQL2022_EXPRESS; Initial Catalog=SahityaSadhnaDB; User ID=sa; Password=sql2022; TrustServerCertificate=True;"
  },
  "Jwt": {
    "Secret": "EA795626-5B4F-4253-AE2C-7560EF8AF51B",
    "Issuer": "AppAPI",
    "Audience": "AppAPI",
    "TokenExpiryInMinutes": "60",
    "RefreshTokenExpiryInDays": 7
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Expressions" ],
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "WithMachineName",
      "WithThreadId",
      "WithExceptionDetails",
      "WithEnvironmentName",
      "FromLogContext"
    ],
    "Properties": {
      "Application": "AppAPI"
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{MachineName}|{RequestId}|{SourceContext}] {Message}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-development-.txt",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff} [{MachineName}|{RequestId}|{SourceContext}] {Message}{NewLine}{Exception}",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true,
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ]
  }
}
  